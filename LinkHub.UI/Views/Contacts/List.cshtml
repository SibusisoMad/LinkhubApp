@model IEnumerable<LinkHub.UI.Models.ContactListViewModel>

@{
    ViewData["Title"] = "Contact List";
}

<h2>Contacts</h2>

    @if (Model == null || !Model.Any())
{
    <div class="alert alert-info mt-4">No contact(s) found.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th class="text-start">Full Name</th>
                <th class="text-start">Email address</th>
                <th class="text-center">Number of linked clients</th>
                <th class="text-start w-auto"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contact in Model)
            {
                <tr>
                    <td class="text-start">
                        <a asp-controller="Contacts" asp-action="Edit" asp-route-id="@contact.ContactId" class="text-decoration-none">@contact.FullName</a>
                    </td>
                    <td class="text-start">@contact.Email</td>
                    <td class="text-center">@contact.NoOfLinkedClients</td>
                    <td class="text-start text-nowrap">
                        @if (contact.LinkedClients != null && contact.LinkedClients.Count > 0)
                        {
                            <div class="dropdown">
                                <button class="btn btn-link dropdown-toggle p-0" type="button" id="dropdownMenuButton-@contact.ContactId" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Unlink
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton-@contact.ContactId">
                                    @foreach (var client in contact.LinkedClients)
                                    {
                                        <li>
                                            <a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#confirmUnlinkModal" data-contact-id="@contact.ContactId" data-client-id="@client.ClientId" data-client-name="@client.ClientName">
                                                @client.ClientName
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="confirmUnlinkModal" tabindex="-1" aria-labelledby="confirmUnlinkModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmUnlinkModalLabel">Confirm Unlink</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to unlink <span id="modalClientName" class="fw-bold"></span> from this contact?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-controller="Contacts" asp-action="Unlink" method="post" class="d-inline" data-ajax="true">
                    <div class="alert alert-danger d-none" data-ajax-error role="alert"></div>
                    <input type="hidden" name="contactId" id="unlinkContactId" />
                    <input type="hidden" name="clientId" id="unlinkClientId" />
                    <input type="hidden" name="returnUrl" value="@Url.Action("List", "Contacts")" />
                    <button type="submit" class="btn btn-danger">Unlink</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            var $confirmUnlinkModal = $('#confirmUnlinkModal');
            if ($confirmUnlinkModal.length === 0) return;

            $confirmUnlinkModal.on('show.bs.modal', function (event) {
                var $button = $(event.relatedTarget);
                if ($button.length === 0) return;

                $('#modalClientName').text($button.data('client-name') || '');
                $('#unlinkContactId').val($button.data('contact-id') || '');
                $('#unlinkClientId').val($button.data('client-id') || '');
            });
        });
    </script>
}
