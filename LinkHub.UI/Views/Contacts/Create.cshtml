@model LinkHub.UI.Models.ContactCreateViewModel

@{
    ViewData["Title"] = "Create Contact";
}

<h2>Create Contact</h2>

<div class="modal fade" id="contactCreateSuccessModal" tabindex="-1" aria-labelledby="contactCreateSuccessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-success text-white">
            <div class="modal-header">
                <h5 class="modal-title" id="contactCreateSuccessModalLabel">Success</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="contactCreateSuccessModalBody">Contact created.</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<form asp-action="Create" method="post" class="mt-4" data-ajax="true" data-ajax-redirect="false" id="contactCreateForm">
    <div class="alert alert-danger d-none" data-ajax-error role="alert"></div>
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Surname" class="form-label"></label>
        <input asp-for="Surname" class="form-control" />
        <span asp-validation-for="Surname" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create Contact</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(function () {
            $('#contactCreateForm').on('ajax:success', function (e, response) {
                if (!response || response.success !== true) return;

                var redirectUrl = response.redirectUrl || '/contacts/list';

                var modalEl = $('#contactCreateSuccessModal').get(0);
                if (!modalEl) {
                    $(location).attr('href', redirectUrl);
                    return;
                }

                var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                modal.show();

                window.setTimeout(function () {
                    $(location).attr('href', redirectUrl);
                }, 1200);

                if (response.validation) {

            $('.text-danger').text('');

            for (var field in response.validation) {

                var messages = response.validation[field];

                var span = $('[data-valmsg-for="' + field + '"]');

                if (span.length) {
                    span.text(messages[0]);
                }
            }
        }

            if (response.error) {

            $('[data-ajax-error]')
                .removeClass('d-none')
                .text(response.error);
        }
            });
        });
    </script>
}
