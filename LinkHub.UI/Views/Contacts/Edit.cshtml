@model LinkHub.UI.Models.ContactEditViewModel

@{
    ViewData["Title"] = "Contacts";
}

<h2>Contact</h2>

@if (Model.ContactUpdatedMessage != null)
{
    <div class="modal fade" id="contactUpdatedModal" tabindex="-1" aria-labelledby="contactUpdatedModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-success text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="contactUpdatedModalLabel">Contact Updated</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @Model.ContactUpdatedMessage
                </div>
            </div>
        </div>
    </div>
}

<ul class="nav nav-tabs" id="contactTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab" aria-controls="details" aria-selected="true">Contact</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="clients-tab" data-bs-toggle="tab" data-bs-target="#clients" type="button" role="tab" aria-controls="clients" aria-selected="false">Client(s)</button>
    </li>
</ul>
<div class="tab-content mt-3" id="contactTabsContent">
    <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
        <form asp-controller="Contacts" asp-action="Update" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Surname" class="form-label"></label>
                <input asp-for="Surname" class="form-control" />
                <span asp-validation-for="Surname" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
    <div class="tab-pane fade" id="clients" role="tabpanel" aria-labelledby="clients-tab">
        @if (Model.ClientsSuccessMessage != null)
        {
            <div class="alert alert-success mt-2" id="clientsSuccessAlert">@Model.ClientsSuccessMessage</div>
        }

        <h4>Linked Clients</h4>
        @if (Model.LinkedClients.Any())
        {
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th class="text-start">Client Name</th>
                        <th class="text-start">Client Code</th>
                        <th class="text-start"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model.LinkedClients)
                    {
                        <tr>
                            <td class="text-start">@client.ClientName</td>
                            <td class="text-start">@client.ClientCode</td>
                            <td class="text-start">
                                <button type="button"
                                        class="btn btn-link text-danger p-0"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmUnlinkClientModal"
                                        data-contact-id="@Model.Id"
                                        data-client-id="@client.ClientId"
                                        data-client-name="@client.ClientName">
                                    Unlink
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info mt-2">No clients found.</div>
        }

        <div class="modal fade" id="confirmUnlinkClientModal" tabindex="-1" aria-labelledby="confirmUnlinkClientModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="confirmUnlinkClientModalLabel">Confirm Unlink</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to unlink <span id="unlinkClientName" class="fw-bold"></span> from this contact?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form asp-controller="Contacts" asp-action="Unlink" method="post" class="d-inline">
                            <input type="hidden" name="contactId" id="unlinkContactId" />
                            <input type="hidden" name="clientId" id="unlinkClientId" />
                            <button type="submit" class="btn btn-danger">Unlink</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <h4 class="mt-4">Link New Client</h4>
        <form asp-controller="Contacts" asp-action="LinkClient" method="post" class="d-flex align-items-end">
            <div class="me-2">
                <select id="clientIdSelect" name="clientId" class="form-select" @(Model.AvailableClients.Any() ? "" : "disabled")>
                    @if (Model.AvailableClients.Any())
                    {
                        foreach (var client in Model.AvailableClients)
                        {
                            <option value="@client.ClientId">@client.ClientName (@client.ClientCode)</option>
                        }
                    }
                    else
                    {
                        <option disabled selected>No available clients to link</option>
                    }
                </select>
            </div>
            <input type="hidden" name="contactId" value="@Model.Id" />
            <button type="submit" class="btn btn-success" @(Model.AvailableClients.Any() ? "" : "disabled")>Link</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const clientsSuccessAlert = document.getElementById('clientsSuccessAlert');
            if (clientsSuccessAlert) {
                const clientsTab = document.getElementById('clients-tab');
                if (clientsTab) {
                    const tab = new bootstrap.Tab(clientsTab);
                    tab.show();
                }

                setTimeout(function () {
                    clientsSuccessAlert.style.display = 'none';
                }, 2000);
            }

            const confirmUnlinkClientModal = document.getElementById('confirmUnlinkClientModal');
            const unlinkClientName = document.getElementById('unlinkClientName');
            const unlinkContactId = document.getElementById('unlinkContactId');
            const unlinkClientId = document.getElementById('unlinkClientId');

            if (confirmUnlinkClientModal && unlinkClientName && unlinkContactId && unlinkClientId) {
                confirmUnlinkClientModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    if (!button) return;

                    const contactId = button.getAttribute('data-contact-id');
                    const clientId = button.getAttribute('data-client-id');
                    const clientName = button.getAttribute('data-client-name');

                    unlinkClientName.textContent = clientName ?? '';
                    unlinkContactId.value = contactId ?? '';
                    unlinkClientId.value = clientId ?? '';
                });
            }

            const contactUpdatedModalEl = document.getElementById('contactUpdatedModal');
            if (contactUpdatedModalEl) {
                const modal = new bootstrap.Modal(contactUpdatedModalEl);
                modal.show();

                setTimeout(function () {
                    window.location.href = '@Url.Action("List", "Contacts")';
                }, 1500);
            }
        });
    </script>
}
