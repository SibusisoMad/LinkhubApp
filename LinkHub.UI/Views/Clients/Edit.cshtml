@model LinkHub.UI.Models.ClientEditViewModel

@{
    ViewData["Title"] = "Edit Client";
}

<h2>Client</h2>

<div id="clientEditPage"
    data-client-id="@Model.Id"
    data-list-url="@Url.Action("List", "Clients")"
    data-page-size="5"></div>

<div class="modal fade" id="clientUpdatedModal" tabindex="-1" aria-labelledby="clientUpdatedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-success text-white">
            <div class="modal-header">
                <h5 class="modal-title" id="clientUpdatedModalLabel">Success</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="clientUpdatedModalBody">
                Client updated.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs" id="clientTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab" aria-controls="details" aria-selected="true">Client</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="contacts-tab" data-bs-toggle="tab" data-bs-target="#contacts" type="button" role="tab" aria-controls="contacts" aria-selected="false">Contact(s)</button>
    </li>
</ul>
<div class="tab-content mt-3" id="clientTabsContent">
    <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
        <form asp-action="Edit" method="post" data-ajax="true" id="clientEditForm">
            <div class="alert alert-danger d-none" data-ajax-error role="alert"></div>
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
    <div class="tab-pane fade" id="contacts" role="tabpanel" aria-labelledby="contacts-tab">
        <div class="alert alert-success mt-2 @(ViewBag.LinkSuccess != null ? "" : "d-none")" id="linkSuccessAlert">@((string)ViewBag.LinkSuccess ?? "")</div>
        <div class="alert alert-success mt-2 @(ViewBag.UnlinkSuccess != null ? "" : "d-none")" id="unlinkSuccessAlert">@((string)ViewBag.UnlinkSuccess ?? "")</div>

        <h4>Linked Contacts</h4>
        <div id="linkedContactsContainer">
            @if (Model.LinkedContacts.Any())
            {
                <table class="table table-bordered table-striped" id="linkedContactsTable">
                    <thead>
                        <tr>
                            <th class="text-start">Contact Full Name</th>
                            <th class="text-start">Contact Email</th>
                            <th class="text-start"></th>
                        </tr>
                    </thead>
                    <tbody id="linkedContactsBody">
                        @foreach (var contact in Model.LinkedContacts)
                        {
                            <tr data-contact-id="@contact.ContactId">
                                <td class="text-start">@contact.FullName</td>
                                <td class="text-start">@contact.Email</td>
                                <td class="text-start">
                                    <button type="button"
                                            class="btn btn-link text-danger p-0"
                                            data-bs-toggle="modal"
                                            data-bs-target="#confirmUnlinkContactModal"
                                            data-client-id="@Model.Id"
                                            data-contact-id="@contact.ContactId"
                                            data-contact-name="@contact.FullName">
                                        Unlink
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mt-2" id="noLinkedContactsAlert">No contacts found.</div>
            }
        </div>

        <div class="modal fade" id="confirmUnlinkContactModal" tabindex="-1" aria-labelledby="confirmUnlinkContactModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="confirmUnlinkContactModalLabel">Confirm Unlink</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to unlink <span id="unlinkContactName" class="fw-bold"></span> from this client?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="UnlinkContact" method="post" class="d-inline" data-ajax="true" id="unlinkContactForm">
                            <input type="hidden" name="clientId" id="unlinkClientId" />
                            <input type="hidden" name="contactId" id="unlinkContactId" />
                            <button type="submit" class="btn btn-danger">Unlink</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <h4 class="mt-4">Link New Contact</h4>
        @if (ViewBag.LinkError != null)
        {
            <div class="modal fade" id="linkErrorModal" tabindex="-1" aria-labelledby="linkErrorModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="linkErrorModalLabel">Error</h5>
                        </div>
                        <div class="modal-body">
                            @ViewBag.LinkError
                        </div>
                    </div>
                </div>
            </div>
        }
        <form asp-action="LinkContact" method="post" class="row g-2 align-items-end" data-ajax="true">
            <input type="hidden" name="clientId" value="@Model.Id" />
            <input type="hidden" name="contactId" id="linkContactId" value="" />
            <div class="col-auto" style="min-width: 360px;">
                <div class="position-relative">
                    <input type="text"
                           id="contactSearch"
                           class="form-control"
                           placeholder="Type at least 3 characters to search..."
                              autocomplete="off"
                              data-search-url="@Url.Action("SearchAvailableContacts", "Clients")" />
                    <div id="contactSearchResults" class="list-group position-absolute w-100 mt-1" style="z-index: 1050; display:none;"></div>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" id="linkContactSubmit" class="btn btn-success" disabled>Link</button>
            </div>
            <div class="col-12">
                <div id="contactSearchStatus" class="form-text"></div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/pages/client-edit.js" asp-append-version="true"></script>
}
