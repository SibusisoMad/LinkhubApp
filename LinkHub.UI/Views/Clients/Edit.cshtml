@model LinkHub.UI.Models.ClientEditViewModel

@{
    ViewData["Title"] = "Edit Client";
}

<h2>Client</h2>

@if ((ViewBag.SuccessMessage as string) == "Client updated.")
{
    <div class="modal fade" id="clientUpdatedModal" tabindex="-1" aria-labelledby="clientUpdatedModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-success text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="clientUpdatedModalLabel">Success</h5>
                </div>
                <div class="modal-body">
                    <p>@ViewBag.SuccessMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<ul class="nav nav-tabs" id="clientTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab" aria-controls="details" aria-selected="true">Client</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="contacts-tab" data-bs-toggle="tab" data-bs-target="#contacts" type="button" role="tab" aria-controls="contacts" aria-selected="false">Contact(s)</button>
    </li>
</ul>
<div class="tab-content mt-3" id="clientTabsContent">
    <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
    <div class="tab-pane fade" id="contacts" role="tabpanel" aria-labelledby="contacts-tab">
        @if (ViewBag.LinkSuccess != null)
        {
            <div class="alert alert-success mt-2" id="linkSuccessAlert">@ViewBag.LinkSuccess</div>
        }
        @if (ViewBag.UnlinkSuccess != null)
        {
            <div class="alert alert-success mt-2" id="unlinkSuccessAlert">@ViewBag.UnlinkSuccess</div>
        }

        <h4>Linked Contacts</h4>
        @if (Model.LinkedContacts.Any())
        {
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th class="text-start">Contact Full Name</th>
                        <th class="text-start">Contact Email</th>
                        <th class="text-start"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contact in Model.LinkedContacts)
                    {
                        <tr>
                            <td class="text-start">@contact.FullName</td>
                            <td class="text-start">@contact.Email</td>
                            <td class="text-start">
                                <button type="button"
                                        class="btn btn-link text-danger p-0"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmUnlinkContactModal"
                                        data-client-id="@Model.Id"
                                        data-contact-id="@contact.ContactId"
                                        data-contact-name="@contact.FullName">
                                    Unlink
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="modal fade" id="confirmUnlinkContactModal" tabindex="-1" aria-labelledby="confirmUnlinkContactModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmUnlinkContactModalLabel">Confirm Unlink</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to unlink <span id="unlinkContactName" class="fw-bold"></span> from this client?
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <form asp-action="UnlinkContact" method="post" class="d-inline">
                                <input type="hidden" name="clientId" id="unlinkClientId" />
                                <input type="hidden" name="contactId" id="unlinkContactId" />
                                <button type="submit" class="btn btn-danger">Unlink</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mt-2">No contacts found.</div>
        }
        <h4 class="mt-4">Link New Contact</h4>
        @if (ViewBag.LinkError != null)
        {
            <div class="modal fade" id="linkErrorModal" tabindex="-1" aria-labelledby="linkErrorModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="linkErrorModalLabel">Error</h5>
                        </div>
                        <div class="modal-body">
                            @ViewBag.LinkError
                        </div>
                    </div>
                </div>
            </div>
        }
        <form asp-action="LinkContact" method="post" class="d-flex align-items-end">
            <input type="hidden" name="clientId" value="@Model.Id" />
            <div class="me-2">
                <select name="contactId" class="form-select" @(Model.AvailableContacts.Any() ? "" : "disabled")>
                    @if (Model.AvailableContacts.Any())
                    {
                        foreach (var contact in Model.AvailableContacts)
                        {
                            <option value="@contact.ContactId">@contact.FullName (@contact.Email)</option>
                        }
                    }
                    else
                    {
                        <option disabled selected>No available contacts to link</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-success" @(Model.AvailableContacts.Any() ? "" : "disabled")>Link</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var contactsTab = document.getElementById('contacts-tab');
            var shouldActivateContactsTab =
                document.getElementById('linkSuccessAlert') ||
                document.getElementById('unlinkSuccessAlert') ||
                document.getElementById('linkErrorModal');

            if (contactsTab && shouldActivateContactsTab) {
                var tab = new bootstrap.Tab(contactsTab);
                tab.show();
            }

            var linkSuccessAlert = document.getElementById('linkSuccessAlert');
            if (linkSuccessAlert) {
                setTimeout(function () { linkSuccessAlert.style.display = 'none'; }, 2000);
            }

            var unlinkSuccessAlert = document.getElementById('unlinkSuccessAlert');
            if (unlinkSuccessAlert) {
                setTimeout(function () { unlinkSuccessAlert.style.display = 'none'; }, 2000);
            }

            var linkErrorModalEl = document.getElementById('linkErrorModal');
            if (linkErrorModalEl) {
                var linkErrorModal = new bootstrap.Modal(linkErrorModalEl);
                linkErrorModal.show();
                setTimeout(function () {
                    linkErrorModal.hide();
                }, 1000);
            }

            var clientUpdatedModalEl = document.getElementById('clientUpdatedModal');
            if (clientUpdatedModalEl) {
                var clientUpdatedModal = new bootstrap.Modal(clientUpdatedModalEl);
                clientUpdatedModal.show();
            }

            var confirmUnlinkContactModalEl = document.getElementById('confirmUnlinkContactModal');
            if (confirmUnlinkContactModalEl) {
                confirmUnlinkContactModalEl.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    if (!button) return;

                    var clientId = button.getAttribute('data-client-id');
                    var contactId = button.getAttribute('data-contact-id');
                    var contactName = button.getAttribute('data-contact-name');

                    var unlinkContactName = document.getElementById('unlinkContactName');
                    var unlinkClientId = document.getElementById('unlinkClientId');
                    var unlinkContactId = document.getElementById('unlinkContactId');

                    if (!unlinkContactName || !unlinkClientId || !unlinkContactId) return;
                    unlinkContactName.textContent = contactName ?? '';
                    unlinkClientId.value = clientId ?? '';
                    unlinkContactId.value = contactId ?? '';
                });
            }
        });
    </script>
}
